{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "openapi-studio-tanstack",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "env": {
    "preview": {
      "name": "openapi-studio-tanstack-preview",
      "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
      },
    },
  },
}
